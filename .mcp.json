{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    },
    "confluent-docs": {
      "command": "uvx",
      "args": [
        "--from", "mcpdoc",
        "mcpdoc",
        "--urls", "Confluent:https://docs.confluent.io/llms.txt",
        "--transport", "stdio"
      ]
    },
    "mcp-confluent": {
      "command": "/opt/homebrew/opt/node@22/bin/npx",
      "args": [
        "-y", "@confluentinc/mcp-confluent",
        "--env-file", "${CONFLUENT_MCP_ENV_FILE}"
      ],
      "env": {
        "CONFLUENT_MCP_ENV_FILE": "${CONFLUENT_MCP_ENV_FILE}",
        "PATH": "/opt/homebrew/opt/node@22/bin:/usr/bin:/bin:/usr/sbin:/sbin"
      }
    },
    "terraform": {
      "command": "/usr/local/bin/terraform-mcp-server",
      "args": []
    },
    "dynatrace": {
      "command": "npx",
      "args": ["-y", "@dynatrace-oss/dynatrace-mcp-server"],
      "env": {
        "DT_ENVIRONMENT": "${DT_ENVIRONMENT}",
        "DT_PLATFORM_TOKEN": "${DT_PLATFORM_TOKEN}",
        "DT_GRAIL_QUERY_BUDGET_GB": "50"
      }
    },
    "grafana": {
      "command": "/Users/jhogan/go/bin/mcp-grafana",
      "args": ["-t", "stdio", "-disable-write"],
      "env": {
        "GRAFANA_URL": "${GRAFANA_URL}",
        "GRAFANA_API_KEY": "${GRAFANA_API_KEY}"
      }
    }
  }
}
