{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    },
    "confluent-docs": {
      "command": "uvx",
      "args": [
        "--from", "mcpdoc",
        "mcpdoc",
        "--urls", "Confluent:https://docs.confluent.io/llms.txt",
        "--transport", "stdio"
      ]
    },
    "mcp-confluent": {
      "command": "npx",
      "args": [
        "-y", "@confluentinc/mcp-confluent",
        "--env-file", "${CONFLUENT_MCP_ENV_FILE}"
      ],
      "env": {
        "CONFLUENT_MCP_ENV_FILE": "${CONFLUENT_MCP_ENV_FILE}"
      }
    },
    "terraform": {
      "command": "npx",
      "args": ["-y", "@hashicorp/terraform-mcp-server"]
    }
  }
}
