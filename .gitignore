.DS_Store
__pycache__/
*.pyc
.env
.flox/
.venv/
.claude.local.md
.claude/settings.local.json
raw/repos/*
!raw/repos/.gitkeep
!raw/repos/fsi-dsp
outputs/charts/*.png
outputs/slides/*.pdf

# Terraform workspaces materialized by /dsp-apply Step 7 (Phase G.1).
# State files, provider plugins, and rendered tfvars are local-only —
# never committed. Recreated per-plan-slug on demand.
outputs/runs/

# Scaffolded output (H.3c) — audit trail lives in wiki/activity/, not in the file tree
outputs/scaffolded/

# Promotion candidates (tools/promote-canon.py) — transient review artifacts.
outputs/promote/

# Client/engagement canon silos are NEVER committed to the shared repo. They live in
# a private overlay repo loaded via CFLT_CANON_EXTERNAL_PATH (see CONTRIBUTING.md).
# Only the acme-bank demo and the scaffold README/.gitkeep stay tracked.
canon/customer/*
canon/engagement/*
!canon/customer/README.md
!canon/customer/.gitkeep
!canon/customer/acme-bank
!canon/customer/acme-bank/**
!canon/engagement/README.md
!canon/engagement/.gitkeep
