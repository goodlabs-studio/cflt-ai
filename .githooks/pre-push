#!/usr/bin/env bash
# Pre-push guard: refuse to push client/engagement canon silos to the shared repo.
#
# Client overlays must live in a PRIVATE overlay repo loaded via
# CFLT_CANON_EXTERNAL_PATH (see CONTRIBUTING.md), never in the shared cflt-ai tree.
# .gitignore already keeps them untracked; this hook is defense-in-depth against a
# stray `git add -f`. The acme-bank demo and scaffold files are allowlisted.
#
# Install:  git config core.hooksPath .githooks
set -euo pipefail

zero="0000000000000000000000000000000000000000"
pattern='^canon/(customer|engagement)/'
allow='^canon/(customer|engagement)/(README\.md|\.gitkeep)$|^canon/customer/acme-bank/'

blocked=0
while read -r _local_ref local_sha _remote_ref remote_sha; do
  [ "$local_sha" = "$zero" ] && continue   # branch deletion
  if [ "$remote_sha" = "$zero" ]; then
    commits=$(git rev-list "$local_sha" --not --all)   # new ref: only its own commits
  else
    commits=$(git rev-list "${remote_sha}..${local_sha}")
  fi
  files=$(for c in $commits; do git diff-tree --no-commit-id --name-only -r "$c"; done | sort -u)
  while IFS= read -r f; do
    [ -z "$f" ] && continue
    if echo "$f" | grep -Eq "$pattern" && ! echo "$f" | grep -Eq "$allow"; then
      echo "BLOCKED: $f — client/engagement canon must not be pushed to the shared repo." >&2
      blocked=1
    fi
  done <<< "$files"
done

if [ "$blocked" -ne 0 ]; then
  echo "pre-push aborted. Move client canon to a private overlay repo (CFLT_CANON_EXTERNAL_PATH)." >&2
  exit 1
fi
exit 0
