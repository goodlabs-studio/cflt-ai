---
# Example inventory for CP mTLS provisioning.
# Copy to hosts.yml and adjust to your environment.

all:
  children:
    cert_authority:
      # The host where the CA private key lives and signing happens.
      # Can be your Ansible controller (use ansible_connection: local)
      # or a dedicated locked-down bastion.
      hosts:
        ca.fidelity.internal:
          ansible_host: 10.20.10.5

    kafka_brokers:
      # Every broker needs: broker_id, broker_ip (for SAN),
      # optional broker_extra_sans (list of "DNS:name" or "IP:addr" strings).
      hosts:
        broker0.kafka.fidelity.internal:
          broker_id: 0
          broker_ip: 10.20.30.40
          broker_extra_sans:
            - DNS:broker0
            - DNS:kafka-lb.kafka.fidelity.internal   # LB/VIP fronting brokers
        broker1.kafka.fidelity.internal:
          broker_id: 1
          broker_ip: 10.20.30.41
          broker_extra_sans:
            - DNS:broker1
            - DNS:kafka-lb.kafka.fidelity.internal
        broker2.kafka.fidelity.internal:
          broker_id: 2
          broker_ip: 10.20.30.42
          broker_extra_sans:
            - DNS:broker2
            - DNS:kafka-lb.kafka.fidelity.internal

    kafka_clients:
      # Each client gets a cert whose CN becomes the Kafka principal
      # for ACL purposes. Pick stable, meaningful CNs.
      hosts:
        app1.fidelity.internal:
          client_cn: fidelity-app1
        app2.fidelity.internal:
          client_cn: fidelity-app2
        connect1.fidelity.internal:
          client_cn: fidelity-connect-worker-1
